import os
import json
import time
import requests
from threading import Thread
from datetime import datetime
from flask import Flask, jsonify, send_from_directory
from flask_cors import CORS

# CONFIGURATION PARAMETERS
UNIVERSE_ID = "18687417158" 
DATA_FILE = "ccu_data.json"
POLLING_INTERVAL_SECONDS = 5  # How often the backend pings the API for live metrics

app = Flask(__name__)
CORS(app)  # Overrides browser security restrictions allowing your frontend to load data cleanly

def get_ccu():
    url = f"https://games.roproxy.com/v1/games?universeIds={UNIVERSE_ID}"
    try:
        response = requests.get(url, timeout=10)
        if response.status_code == 200:
            data = response.json()
            if 'data' in data and len(data['data']) > 0:
                return data['data'][0].get('playing', 0)
    except Exception as e:
        print(f"Error fetching telemetry from RoProxy: {e}")
    return None

def background_telemetry_loop():
    """Background engine that continuously records and saves historical analytics logs."""
    print("Background telemetry gathering loop initialized successfully.")
    while True:
        # 1. Load history safely
        if os.path.exists(DATA_FILE) and os.path.getsize(DATA_FILE) > 0:
            try:
                with open(DATA_FILE, 'r') as f:
                    data_history = json.load(f)
            except json.JSONDecodeError:
                data_history = []
        else:
            data_history = []

        if not isinstance(data_history, list):
            data_history = []

        # 2. Fetch fresh user numbers
        new_ccu = get_ccu()
        
        if new_ccu is not None:
            new_entry = {
                "t": datetime.now().strftime("%Y-%m-%d %H:%M:%S"), 
                "v": new_ccu
            }
            data_history.append(new_entry)
            
            # OPTIONAL HISTORICAL RETENTION MANAGEMENT:
            # We preserve the last 5,000 metrics so your historical calendars, tables, and weight charts 
            # don't get wiped out like they did at the 100 limit.
            if len(data_history) > 5000:
                data_history = data_history[-5000:]
                
            with open(DATA_FILE, 'w') as f:
                json.dump(data_history, f, indent=4)
            print(f"[{new_entry['t']}] Registered Live CCU: {new_ccu} (Total cached logs: {len(data_history)})")
        else:
            print("Skipping telemetry collection frame: Target server rejected proxy handshakes.")
            
        time.sleep(POLLING_INTERVAL_SECONDS)

# API ROUTES FOR THE ENGINE
@app.route('/')
def serve_dashboard():
    """Serves the main dashboard application script interface."""
    return send_from_directory('.', 'index.html')

@app.route('/ccu_data.json')
def serve_ccu_data_json():
    """Endpoint serving historical sequence records used by baseline analytical grids."""
    if os.path.exists(DATA_FILE):
        try:
            with open(DATA_FILE, 'r') as f:
                return jsonify(json.load(f))
        except Exception:
            return jsonify([])
    return jsonify([])

@app.route('/api/ccu/live')
def serve_live_telemetry_stream():
    """Provides an instant single-point payload lookup for real-time tracking engines."""
    current_live_value = get_ccu()
    if current_live_value is None:
        # Fallback to the latest record in the database if proxy hits rate-limits
        if os.path.exists(DATA_FILE):
            try:
                with open(DATA_FILE, 'r') as f:
                    cached_records = json.load(f)
                    if cached_records:
                        return jsonify({"t": cached_records[-1]["t"], "v": cached_records[-1]["v"], "live": False})
            except Exception:
                pass
        current_live_value = 0
        
    return jsonify({
        "t": datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
        "v": current_live_value,
        "live": True
    })

if __name__ == '__main__':
    # Start the data collection background worker thread before launching the web node
    telemetry_worker = Thread(target=background_telemetry_loop, daemon=True)
    telemetry_worker.start()
    
    # Launch web service deployment node
    app.run(host='0.0.0.0', port=5000, debug=False)
