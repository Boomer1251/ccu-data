import os
import json
import time
import re
import requests
from threading import Thread
from datetime import datetime
from bs4 import BeautifulSoup
from flask import Flask, jsonify, send_from_directory
from flask_cors import CORS

# CONFIGURATION VARIABLES
UNIVERSE_ID = "18687417158" 
ROLIMONS_URL = f"https://www.rolimons.com/game/{UNIVERSE_ID}"
DATA_FILE = "ccu_data.json"
POLLING_INTERVAL_SECONDS = 15  # Background interval checking for updates

app = Flask(__name__)
CORS(app)  # Bypasses local browser security policies

def get_ccu_from_rolimons():
    """Scrapes live player counts looking directly for the game_stat_data class."""
    headers = {
        "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36",
        "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,image/webp,*/*;q=0.8",
        "Accept-Language": "en-US,en;q=0.5"
    }
    
    try:
        response = requests.get(ROLIMONS_URL, headers=headers, timeout=15)
        if response.status_code != 200:
            print(f"Rolimons returned alternative response status code: {response.status_code}")
            return None
            
        soup = BeautifulSoup(response.text, 'html.parser')
        
        # Method 1: Look for your inspected class container structure inside standard layout panels
        stat_boxes = soup.find_all(class_='stat-box') or soup.find_all('div', class_=lambda c: c and 'stat' in c)
        
        for box in stat_boxes:
            # Check if this panel explicitly references active players
            box_text = box.get_text().lower()
            if 'player' in box_text or 'playing' in box_text:
                target_element = box.find(class_='game_stat_data') or box.find(class_='stat-value')
                if target_element:
                    digits_only = re.sub(r'[^\d]', '', target_element.text)
                    if digits_only:
                        return int(digits_only)

        # Method 2: Isolated class scanner fallback if layout structure wraps items loosely
        elements = soup.find_all(class_='game_stat_data')
        for el in elements:
            # Traverse upwards or sideways to confirm it's not the visits or favorites count
            parent_text = el.parent.get_text().lower() if el.parent else ""
            prev_text = el.find_previous().get_text().lower() if el.find_previous() else ""
            
            if 'player' in parent_text or 'playing' in parent_text or 'player' in prev_text or 'playing' in prev_text:
                digits_only = re.sub(r'[^\d]', '', el.text)
                if digits_only:
                    return int(digits_only)
                    
        # Method 3: Direct fallback to first populated instance if contextual validation was too strict
        if elements:
            digits_only = re.sub(r'[^\d]', '', elements[0].text)
            if digits_only:
                return int(digits_only)

    except Exception as e:
        print(f"Exception encountered running parsing scanner: {e}")
        
    return None

def background_telemetry_loop():
    """Background engine tracking live metrics and maintaining historical tracking logs."""
    print("Background telemetry scraper thread started.")
    while True:
        # Load database safely
        if os.path.exists(DATA_FILE) and os.path.getsize(DATA_FILE) > 0:
            try:
                with open(DATA_FILE, 'r') as f:
                    data_history = json.load(f)
            except json.JSONDecodeError:
                data_history = []
        else:
            data_history = []

        if not isinstance(data_history, list):
            data_history = []

        # Extract targeted data point
        new_ccu = get_ccu_from_rolimons()
        
        if new_ccu is not None:
            new_entry = {
                "t": datetime.now().strftime("%Y-%m-%d %H:%M:%S"), 
                "v": new_ccu
            }
            
            # Save if data changed or if 5 minutes have elapsed since the last log row
            should_append = (
                len(data_history) == 0 or 
                data_history[-1]["v"] != new_ccu or 
                (datetime.now() - datetime.strptime(data_history[-1]["t"], "%Y-%m-%d %H:%M:%S")).total_seconds() > 300
            )
            
            if should_append:
                data_history.append(new_entry)
                
                # Cap logs at 5,000 items to protect baseline capacity limits
                if len(data_history) > 5000:
                    data_history = data_history[-5000:]
                    
                with open(DATA_FILE, 'w') as f:
                    json.dump(data_history, f, indent=4)
                print(f"[{new_entry['t']}] Saved Rolimons Telemetry Matrix: {new_ccu}")
            else:
                print(f"Live telemetry steady at: {new_ccu} (Skipping duplicate entries)")
        else:
            print("Skipping database entry: Scraper failed to resolve live element targets.")
            
        time.sleep(POLLING_INTERVAL_SECONDS)

# APPS INTERFACE NETWORKING ROUTES
@app.route('/')
def serve_dashboard():
    return send_from_directory('.', 'index.html')

@app.route('/ccu_data.json')
def serve_ccu_data_json():
    if os.path.exists(DATA_FILE):
        try:
            with open(DATA_FILE, 'r') as f:
                return jsonify(json.load(f))
        except Exception:
            return jsonify([])
    return jsonify([])

@app.route('/api/ccu/live')
def serve_live_telemetry_stream():
    """Endpoint serving real-time instantaneous lookups directly to frontend charts."""
    current_live_value = get_ccu_from_rolimons()
    
    if current_live_value is None:
        # Fallback to the latest record in our JSON file if connection drops
        if os.path.exists(DATA_FILE):
            try:
                with open(DATA_FILE, 'r') as f:
                    cached_records = json.load(f)
                    if cached_records:
                        return jsonify({"t": cached_records[-1]["t"], "v": cached_records[-1]["v"], "live": False})
            except Exception:
                pass
        current_live_value = 0
        
    return jsonify({
        "t": datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
        "v": current_live_value,
        "live": True
    })

if __name__ == '__main__':
    # Initialize background process thread before deploying web routing engine
    telemetry_worker = Thread(target=background_telemetry_loop, daemon=True)
    telemetry_worker.start()
    
    # Launch local service port mapping node
    app.run(host='0.0.0.0', port=5000, debug=False)
